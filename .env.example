# ============================================
# Vacapp - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# Base de datos: vacapp
# Usuario por defecto: vacapp_user
# Contraseña por defecto: vacapp_password

# ============================================
# Database Configuration
# ============================================
# DATABASE_URL: Connection string para MySQL
# Formato: jdbc:mysql://[host]:[puerto]/[database]?[opciones]
DATABASE_URL=jdbc:mysql://localhost:3306/vacapp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# Usuario de base de datos
DATABASE_USERNAME=vacapp_user

# Contraseña de base de datos (CAMBIAR EN PRODUCCIÓN)
DATABASE_PASSWORD=vacapp_password

# ============================================
# JPA/Hibernate Configuration
# ============================================
# ddl-auto options: validate, update, create, create-drop
# - validate: valida sin hacer cambios (RECOMENDADO en producción)
# - update: crea/actualiza tablas automáticamente
# - create: crea las tablas (elimina datos existentes)
DDL_AUTO=validate

# Mostrar SQL en logs
SHOW_SQL=false

# ============================================
# JWT Configuration
# ============================================
# Generate a secure 256-bit (32 bytes) secret key with:
# macOS/Linux: openssl rand -base64 32
# Windows: certutil -randfile temp.bin 32 && certutil -encode temp.bin temp.txt
JWT_SECRET=vacapp-default-secret-key-minimum-256-bits-32-bytes-change-in-production

# Token expiration time in milliseconds
# 86400000 = 24 horas
# 3600000 = 1 hora
JWT_EXPIRATION=86400000

# JWT Issuer (optional)
JWT_ISSUER=vacapp

# ============================================
# Server Configuration
# ============================================
# Puerto donde ejecuta la aplicación
SERVER_PORT=8080

# ============================================
# Logging Configuration
# ============================================
# Log levels: TRACE, DEBUG, INFO, WARN, ERROR
APP_LOG_LEVEL=INFO
USERS_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=INFO
WEB_LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN

# Archivo de log
LOG_FILE=logs/vacapp.log

# ============================================
# Spring Profile
# ============================================
# Options: dev, test, prod
# dev:  Debug logs habilitados, Swagger ON
# prod: Info logs, stack traces OFF
SPRING_PROFILES_ACTIVE=dev

# ============================================
# CORS Configuration
# ============================================
# Orígenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ============================================
# Notes / Notas
# ============================================
# DESARROLLO:
# - En development, los valores por defecto funcionan bien
# - Ejecutar: ./mvnw spring-boot:run
#
# PRODUCCIÓN:
# - CAMBIAR JWT_SECRET (generar uno nuevo)
# - CAMBIAR DATABASE_PASSWORD (contraseña fuerte)
# - Usar DATABASE_URL con host/puerto de producción
# - Cambiar SPRING_PROFILES_ACTIVE=prod
# - Habilitar HTTPS/SSL
# - Usar SHOW_SQL=false
# - Usar DDL_AUTO=validate
#
# Base de datos:
# - Crear base de datos: CREATE DATABASE vacapp CHARACTER SET utf8mb4
# - Crear usuario: CREATE USER 'vacapp_user'@'localhost' IDENTIFIED BY 'password'
# - Otorgar permisos: GRANT ALL PRIVILEGES ON vacapp.* TO 'vacapp_user'@'localhost'
