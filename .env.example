# ============================================
# Vacapp - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Database Configuration
# ============================================
DB_URL=jdbc:mysql://localhost:3306/vacapp?useSSL=true&requireSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=vacapp_user
DB_PASSWORD=your_secure_database_password_here

# ============================================
# JWT Configuration
# ============================================
# Generate a secure 256-bit (32 bytes) secret key with:
# openssl rand -base64 32
JWT_SECRET=your_256_bit_jwt_secret_key_here_minimum_32_bytes_for_hs256_algorithm_security

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080

# ============================================
# Security Configuration
# ============================================
# Enable HTTPS requirement in production
REQUIRE_SSL=false

# Enable secure cookies in production (requires HTTPS)
COOKIE_SECURE=false

# ============================================
# Spring Profile
# ============================================
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Notes
# ============================================
# - In production, ALWAYS set JWT_SECRET via environment variable (never hardcode)
# - Use strong, randomly generated passwords for DB_PASSWORD
# - Set REQUIRE_SSL=true and COOKIE_SECURE=true in production with HTTPS
# - Keep this file updated when adding new environment variables
